# Flask environment: development | testing | production
FLASK_ENV=

# Required in production. Generate with: openssl rand -base64 32
SECRET_KEY=

# Required in production. Example: redis://localhost:6379/0
RATELIMIT_STORAGE_URI=

# Optional: bind host (default: 0.0.0.0)
HOST=127.0.0.1

# Optional: bind port (default: 5000)
PORT=5000
